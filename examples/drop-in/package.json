{
  "name": "@acture/example-drop-in",
  "version": "0.0.0",
  "private": true,
  "description": "Phase 2 worked example: an existing tiny app gets a palette + MCP bolt-on in 5 minutes. Demonstrates the drop-in / footprint-minimizer path.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "mcp": "tsx scripts/mcp-server.ts"
  },
  "dependencies": {
    "@acture/hotkeys": "workspace:*",
    "@acture/mcp": "workspace:*",
    "@acture/palette-react": "workspace:*",
    "@acture/state-zustand": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "acture": "workspace:*",
    "cmdk": "^1.0.0",
    "immer": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tinykeys": "^3.0.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
