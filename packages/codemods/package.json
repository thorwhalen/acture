{
  "name": "acture-codemods",
  "version": "1.1.0",
  "description": "Codemod CLI for adopting acture in an existing TypeScript/React codebase. Single npx-invokable runner with a manifest of structural transforms (research-4 §B.5).",
  "license": "Apache-2.0",
  "author": "Thor Whalen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorwhalen/acture.git",
    "directory": "packages/codemods"
  },
  "homepage": "https://github.com/thorwhalen/acture#readme",
  "bugs": "https://github.com/thorwhalen/acture/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "migrations.json",
    "LICENSE"
  ],
  "bin": {
    "acture-codemods": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "acture",
    "codemods",
    "migration",
    "ts-morph",
    "wrap-mutation",
    "ast-transform"
  ],
  "publishConfig": {
    "access": "public"
  }
}
