{
  "name": "acture-state-zustand",
  "version": "1.0.0",
  "description": "acture StateAdapter for zustand + zustand/middleware/immer. Phase 1's documented happy path.",
  "license": "Apache-2.0",
  "author": "Thor Whalen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorwhalen/acture.git",
    "directory": "packages/state-zustand"
  },
  "homepage": "https://github.com/thorwhalen/acture#readme",
  "bugs": "https://github.com/thorwhalen/acture/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "acture": "workspace:*",
    "immer": "^11.0.0 || ^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "acture": "workspace:*",
    "immer": "^11.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zustand": "^5.0.0"
  },
  "keywords": ["acture", "zustand", "immer", "state", "command-dispatch"],
  "publishConfig": {
    "access": "public"
  }
}
