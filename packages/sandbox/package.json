{
  "name": "acture-sandbox",
  "version": "0.0.0",
  "description": "acture sandbox — the isolation seam for an extension system: one ExtensionRunner port plus an in-process transport. Swap in Worker / iframe / QuickJS / isolated-vm transports when authors are untrusted.",
  "license": "Apache-2.0",
  "author": "Thor Whalen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorwhalen/acture.git",
    "directory": "packages/sandbox"
  },
  "homepage": "https://github.com/thorwhalen/acture#readme",
  "bugs": "https://github.com/thorwhalen/acture/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "acture": "^1.0.0"
  },
  "devDependencies": {
    "acture": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "acture",
    "sandbox",
    "extensions",
    "plugins",
    "isolation",
    "command-dispatch"
  ],
  "publishConfig": {
    "access": "public"
  }
}
