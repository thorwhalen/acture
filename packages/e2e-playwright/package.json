{
  "name": "acture-e2e-playwright",
  "version": "1.1.0",
  "description": "acture e2e adapter for Playwright. Record / compose / replay command sequences; dispatch through the page; e2e is a macro with assertions.",
  "license": "Apache-2.0",
  "author": "Thor Whalen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorwhalen/acture.git",
    "directory": "packages/e2e-playwright"
  },
  "homepage": "https://github.com/thorwhalen/acture#readme",
  "bugs": "https://github.com/thorwhalen/acture/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fixture": {
      "types": "./dist/fixture.d.ts",
      "import": "./dist/fixture.js",
      "require": "./dist/fixture.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "acture": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "acture": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "acture",
    "e2e",
    "playwright",
    "macros",
    "command-sequence",
    "command-dispatch",
    "testing"
  ],
  "publishConfig": {
    "access": "public"
  }
}
