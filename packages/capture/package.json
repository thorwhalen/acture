{
  "name": "acture-capture",
  "version": "0.2.0",
  "description": "Drive a command-dispatch app through a narrated journey, screenshot before/after each command, and emit a manifest — an illustrated manual / narrated video from the acture command registry.",
  "license": "Apache-2.0",
  "author": "Thor Whalen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorwhalen/acture.git",
    "directory": "packages/capture"
  },
  "homepage": "https://github.com/thorwhalen/acture#readme",
  "bugs": "https://github.com/thorwhalen/acture/issues",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "acture": "^1.0.0",
    "acture-e2e-playwright": "^1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "acture": "workspace:*",
    "acture-e2e-playwright": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "acture",
    "capture",
    "storybook",
    "manual",
    "screenshot",
    "playwright",
    "command-dispatch",
    "documentation"
  ],
  "publishConfig": {
    "access": "public"
  }
}
